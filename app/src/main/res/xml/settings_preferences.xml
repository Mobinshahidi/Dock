<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ===== Display ===== -->
    <PreferenceCategory
        android:title="@string/section_display"
        android:layout="@layout/preference_category_custom" />

    <SwitchPreferenceCompat
        android:key="@string/pref_key_oled_mode"
        android:title="@string/pref_oled_title"
        android:summary="@string/pref_oled_summary"
        android:defaultValue="false" />

    <SwitchPreferenceCompat
        android:key="@string/pref_key_night_dim"
        android:title="@string/pref_night_dim_title"
        android:summary="@string/pref_night_dim_summary"
        android:defaultValue="true" />

    <ListPreference
        android:key="@string/pref_key_night_dim_start"
        android:title="@string/pref_night_dim_start_title"
        android:summary="@string/pref_night_dim_start_summary"
        android:entries="@array/night_dim_time_labels"
        android:entryValues="@array/night_dim_time_values"
        android:defaultValue="22"
        android:dependency="@string/pref_key_night_dim" />

    <ListPreference
        android:key="@string/pref_key_night_dim_end"
        android:title="@string/pref_night_dim_end_title"
        android:summary="@string/pref_night_dim_end_summary"
        android:entries="@array/night_dim_end_time_labels"
        android:entryValues="@array/night_dim_end_time_values"
        android:defaultValue="7"
        android:dependency="@string/pref_key_night_dim" />

    <!-- ===== Clock ===== -->
    <PreferenceCategory
        android:title="@string/section_clock"
        android:layout="@layout/preference_category_custom" />

    <ListPreference
        android:key="@string/pref_key_clock_position"
        android:title="@string/pref_clock_position_title"
        android:summary="@string/pref_clock_position_summary"
        android:entries="@array/clock_position_labels"
        android:entryValues="@array/clock_position_values"
        android:defaultValue="left" />

    <SeekBarPreference
        android:key="@string/pref_key_clock_font_size"
        android:title="@string/pref_clock_font_size_title"
        android:summary="@string/pref_clock_font_size_summary"
        android:max="200"
        android:defaultValue="100" />

    <SeekBarPreference
        android:key="@string/pref_key_date_font_size"
        android:title="@string/pref_date_font_size_title"
        android:summary="@string/pref_date_font_size_summary"
        android:max="200"
        android:defaultValue="100" />

    <ListPreference
        android:key="@string/pref_key_clock_font"
        android:title="@string/pref_clock_font_title"
        android:summary="@string/pref_clock_font_summary"
        android:entries="@array/clock_font_labels"
        android:entryValues="@array/clock_font_values"
        android:defaultValue="default" />

    <Preference
        android:key="clock_font_upload"
        android:title="@string/clock_font_upload"
        android:summary="@string/pref_clock_font_summary" />

    <Preference
        android:key="@string/pref_key_clock_color"
        android:title="@string/pref_clock_color_title"
        android:summary="@string/pref_clock_color_summary" />

    <!-- ===== Slideshow ===== -->
    <PreferenceCategory
        android:title="@string/section_slideshow"
        android:layout="@layout/preference_category_custom" />

    <SwitchPreferenceCompat
        android:key="@string/pref_key_slideshow_enabled"
        android:title="@string/pref_slideshow_title"
        android:summary="@string/pref_slideshow_summary"
        android:defaultValue="true" />

    <Preference
        android:key="pick_photos"
        android:title="@string/slideshow_pick_photos"
        android:summary="@string/slideshow_no_photos" />

    <ListPreference
        android:key="@string/pref_key_slideshow_interval"
        android:title="@string/slideshow_interval"
        android:entries="@array/slideshow_interval_labels"
        android:entryValues="@array/slideshow_interval_values"
        android:defaultValue="60000"
        android:dependency="@string/pref_key_slideshow_enabled" />

    <!-- ===== Widgets ===== -->
    <PreferenceCategory
        android:title="@string/section_widgets"
        android:layout="@layout/preference_category_custom" />

    <SwitchPreferenceCompat
        android:key="@string/pref_key_widgets_enabled"
        android:title="@string/pref_widgets_title"
        android:summary="@string/pref_widgets_summary"
        android:defaultValue="true" />

    <ListPreference
        android:key="@string/pref_key_widget_slot_count"
        android:title="@string/widget_slot_count"
        android:entries="@array/widget_slot_count_labels"
        android:entryValues="@array/widget_slot_count_values"
        android:defaultValue="1"
        android:dependency="@string/pref_key_widgets_enabled" />

    <Preference
        android:key="manage_slot_1"
        android:title="@string/widget_manage_slot"
        android:summary="@string/widget_pick_for_slot"
        android:dependency="@string/pref_key_widgets_enabled" />

    <ListPreference
        android:key="slot_size_1"
        android:title="@string/pref_slot_size_title"
        android:summary="@string/pref_slot_size_summary"
        android:entries="@array/slot_size_labels"
        android:entryValues="@array/slot_size_values"
        android:defaultValue=""
        android:dependency="@string/pref_key_widgets_enabled" />

    <Preference
        android:key="manage_slot_2"
        android:title="@string/widget_manage_slot"
        android:summary="@string/widget_pick_for_slot"
        android:dependency="@string/pref_key_widgets_enabled"
        android:visible="false" />

    <ListPreference
        android:key="slot_size_2"
        android:title="@string/pref_slot_size_title"
        android:summary="@string/pref_slot_size_summary"
        android:entries="@array/slot_size_labels"
        android:entryValues="@array/slot_size_values"
        android:defaultValue=""
        android:dependency="@string/pref_key_widgets_enabled"
        android:visible="false" />

    <Preference
        android:key="manage_slot_3"
        android:title="@string/widget_manage_slot"
        android:summary="@string/widget_pick_for_slot"
        android:dependency="@string/pref_key_widgets_enabled"
        android:visible="false" />

    <ListPreference
        android:key="slot_size_3"
        android:title="@string/pref_slot_size_title"
        android:summary="@string/pref_slot_size_summary"
        android:entries="@array/slot_size_labels"
        android:entryValues="@array/slot_size_values"
        android:defaultValue=""
        android:dependency="@string/pref_key_widgets_enabled"
        android:visible="false" />

    <!-- ===== Auto-start ===== -->
    <PreferenceCategory
        android:title="@string/section_autostart"
        android:layout="@layout/preference_category_custom" />

    <Preference
        android:key="auto_start_guide"
        android:title="@string/pref_autostart_title"
        android:summary="@string/pref_autostart_summary"
        android:selectable="false" />

    <!-- ===== About ===== -->
    <PreferenceCategory
        android:title="@string/section_about"
        android:layout="@layout/preference_category_custom" />

    <Preference
        android:key="about_license"
        android:title="@string/about_license"
        android:summary="@string/about_repo"
        android:selectable="false" />

</PreferenceScreen>