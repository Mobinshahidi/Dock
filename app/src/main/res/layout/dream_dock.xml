<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 1 — Dream content layout.
  Center-aligned ConstraintLayout with clock and date.
  Slideshow (photo background) and widget rail are TODO stubs
  inserted via code in DockDreamService to allow dynamic
  show/hide without re-inflating.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dream_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    android:background="@color/bg_dark">

    <!--
      TODO (Phase 3): Photo slideshow background
      Replace the static background with a PhotoView or
      ImageView that crossfades between user-selected photos,
      with a semi-transparent black scrim overlay.
    -->

    <!--
      TODO (Phase 3): Scrim overlay
      <View android:id="@+id/scrim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:visibility="gone" />
    -->

    <!-- Clock — large, thin-weight, primary text color -->
    <TextClock
        android:id="@+id/clock_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontWeight="300"
        android:textColor="@color/text_primary"
        android:textSize="120sp"
        android:format12Hour="hh:mm"
        android:format24Hour="HH:mm"
        app:layout_constraintBottom_toTopOf="@+id/date_display"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Date line — smaller, muted opacity via alpha channel -->
    <TextClock
        android:id="@+id/date_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontWeight="300"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:alpha="0.6"
        android:format12Hour="EEEE, MMMM d"
        android:format24Hour="EEEE, MMMM d"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/clock_display" />

    <!--
      TODO (Phase 4): Widget rail
      A horizontal LinearLayout or ConstraintLayout group
      on the right/bottom side containing 1–3 AppWidgetHostView
      slots. Each slot in a borderless rounded container with
      @color/bg_surface background.
      When disabled (widgets_enabled=false), this entire group
      is removed from layout and clock recenters/scales up.
    -->

</androidx.constraintlayout.widget.ConstraintLayout>